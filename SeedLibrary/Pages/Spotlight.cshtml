@page
@using System.Buffers
@model SeedLibrary.Pages.SpotlightSeeds.SpotlightSeedsModel

@{
    ViewData["Title"] = "Seed Spotlight";
}

<link rel="stylesheet" type="text/css" href="~/css/spotlight.css">

<script>
    const d = new Date();
    let currentmonthindex = d.getMonth();
    let months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    var currentmonth = months[currentmonthindex];
</script>

<div class="row mb-auto">
    <div class="row mb-4">
        <div class="col-sm-6">
            <h2 style="border-bottom: 3vh solid #337ab7">Seed Spotlight</h2>
            <div class="borderedcontainer">
                <div style="overflow-y:scroll; height:450px">
                    <!-- TEMPORARY - NEED TO CHANGE TO TAKE ONLY SEED SPOTLIGHT ONCE DATABASE FINALISED -->
                    @for (int i = 0; i < Model.Seeds.Count; i++)
                    {
                        <div class="cardspotlight">
                            <!-- TEMPORARY - NEEDS TO BE SEED IMAGE ONCE ADDED TO THE DATABASE -->
                            <div class="row">
                                <div class="col-sm-4">
                                    <img src="/images/Vegetable.png" alt="Seed Library" style="width: 80px; height: 80px" />
                                </div>
                                <div class="col-sm-8">
                                    <p>@Model.Seeds[i].Variety.VarietyName @Model.Seeds[i].Variety.CommonName.Name</p>
                                    <a asp-page="/Seeds/Details" id="info" asp-route-id="@Model.Seeds[i].SeedId">More Information</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @{
                var prevDisabled = !Model.Seeds.HasPreviousPage ? "disabled" : "";
                var nextDisabled = !Model.Seeds.HasNextPage ? "disabled" : "";
            }

            <a asp-page="./SpotlightSeeds"
               asp-route-sortOrder="@Model.CurrentSort"
               asp-route-currentFilter="@Model.CurrentFilter"
               asp-route-pageIndex="@(Model.Seeds.PageIndex - 1)"
               class="btn btn-primary @prevDisabled">
                Previous
            </a>

            <a asp-page="./SpotlightSeeds"
               asp-route-sortOrder="@Model.CurrentSort"
               asp-route-currentFilter="@Model.CurrentFilter"
               asp-route-pageIndex="@(Model.Seeds.PageIndex + 1)"
               class="btn btn-primary @nextDisabled">
                Next
            </a>
        </div>

        <div class="col-sm-6">
            <h3 style="border-bottom: 3vh solid #AAD373">In Season Seeds</h3>
            <div class="borderedcontainer" id="inseasonsquare">
                <!-- TEMPORARY - NOW TAKES FROM PLANTINGDATE MONTHS -->
                @for (int i = 0; i < Model.InSeasonSeeds.Count; i++)
                {
                    <p>
                        @Model.InSeasonSeeds[i].Variety.VarietyName @Model.InSeasonSeeds[i].Variety.CommonName.Name
                    </p>
                }
            </div>
            <div class="row">
                <p>If you want to get started with your garden this month the seeds above are a good option!</p>
                <p>To see the full variety of seeds in our catalogue, please view our inventory.</p>
                <button type="button" class="webbutton" id="seedinvbut" onclick="location.href='/Seeds'">View Seed Inventory</button>
                <button type="button" class="webbutton" id="returnhome" onclick="location.href='/Index'">Return to Homepage</button>
            </div>
        </div>
    </div>
</div>