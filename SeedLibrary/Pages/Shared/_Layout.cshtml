<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Seed Library</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SeedLibrary.styles.css" asp-append-version="true" />
</head>
<body>
    <header style= "background-color: #F46E15;" >
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <img src="/images/Library_logo.png" alt="Seed Library" style= "width: 125px;">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item" style="border-bottom: 4px solid #FDB717; background-color: white;">
                            <a class="nav-link text-dark" style="font-family: 'Lato-Bold'; font-size: 23px;" asp-area="" asp-page="/About">About Us</a>
                        </li>
                        <li class="nav-item" style="border-bottom: 4px solid #8BC441; background-color: white;">
                            <a class="nav-link text-dark" style="font-family: 'Lato-Bold'; font-size: 23px;" asp-area="" asp-page="/Seeds/Index">Search Our Inventory</a>
                        </li>
                        <li class="nav-item" style="border-bottom: 4px solid #337ab7; background-color: white;">
                            <a class="nav-link text-dark" style="font-family: 'Lato-Bold'; font-size: 23px;" asp-area="" asp-page="/Courses/Index">Spotlight</a>
                        </li>
                        <li class="nav-item" style="border-bottom: 4px solid #EC373C; background-color: white;">
                            <a class="nav-link text-dark" style="font-family: 'Lato-Bold'; font-size: 23px;" asp-area="" asp-page="/Instructors/Index">Order</a>
                        </li>
                        <li class="nav-item" style="border-bottom: 4px solid #F46E15; background-color: white;">
                            <a class="nav-link text-dark" style="font-family: 'Lato-Bold'; font-size: 23px;" asp-area="" asp-page="/Departments/Index">Checkout</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer" style= "background-color: #F9B71B; color: black;">
        <div class="container">
            &copy; 2026 - Faulkner Country Library Garden Program - Seed Library - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
