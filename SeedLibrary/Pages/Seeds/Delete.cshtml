@page
@model SeedLibrary.Pages.Seeds.DeleteModel

@{
    ViewData["Title"] = "Delete";
}
     <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />


<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Seed</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Common Name
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Seed.Variety.CommonNameName)
        </dd>
        <dt class="col-sm-2">
            Variety
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Seed.Variety.VarietyName)
        </dd>
        <dt class="col-sm-2">
            Source
        </dt>
        <dd class="col-sm-10">
            @foreach (var donation in Model.Seed.Donations)
            {
                <div>@donation.Source.SourceName - @donation.Year</div>
            }
        </dd>
        <dt class="col-sm-2">
            Growing Season
        </dt>
        <dd class="col-sm-10">
            @foreach (var growing in Model.Seed.Growings)
            {
                <div>
                    @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(growing.PlantingDate.StartMonth)
                    -
                    @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(growing.PlantingDate.EndMonth)
                </div>
            }
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Seed.Variety.Depth)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Seed.Variety.Depth)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Seed.Count)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Seed.Count)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Seed.Note)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Seed.Note)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Seed.SeedId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./Index">Back to List</a>
    </form>
</div>