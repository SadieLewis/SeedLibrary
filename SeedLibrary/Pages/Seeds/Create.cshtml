@page
@model SeedLibrary.Pages.Seeds.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>Seed</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="SeedPacket.VarietyName" class="control-label"></label>
                <select asp-for="SeedPacket.VarietyName" class ="form-control" asp-items="ViewBag.VarietyName" ></select>
            </div>
            <div class="form-group">
                <label asp-for="SeedPacket.Count" class="control-label"></label>
                <input asp-for="SeedPacket.Count" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="SeedPacket.Note" class="control-label"></label>
                <input asp-for="SeedPacket.Note" class="form-control" />
                <span asp-validation-for="SeedPacket.Note" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SeedPacket.Donations" class="control-label"></label>
                <select asp-for="SeedPacket.Donations" class ="form-control" asp-items="ViewBag.Donations" ></select>
            </div>
            <div class="form-group">
                <label asp-for="SeedPacket.Growings" class="control-label"></label>
                <select asp-for="SeedPacket.Growings" class ="form-control" asp-items="ViewBag.Growings" ></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
    <div>
    </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}