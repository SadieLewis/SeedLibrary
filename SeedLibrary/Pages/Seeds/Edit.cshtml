@page
@model SeedLibrary.Pages_Seeds.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>SeedPacket</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="SeedPacket.SeedId" />
            <div class="form-group">
                <label asp-for="SeedPacket.Count" class="control-label"></label>
                <input asp-for="SeedPacket.Count" class="form-control" />
                <span asp-validation-for="SeedPacket.Count" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SeedPacket.Note" class="control-label"></label>
                <input asp-for="SeedPacket.Note" class="form-control" />
                <span asp-validation-for="SeedPacket.Note" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SeedPacket.VarietyName" class="control-label"></label>
                <select asp-for="SeedPacket.VarietyName" class="form-control" asp-items="ViewBag.VarietyName" ></select>
                <span asp-validation-for="SeedPacket.VarietyName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
