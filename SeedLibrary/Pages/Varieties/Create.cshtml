@page
@model SeedLibrary.Pages.Varieties.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
             <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        
        <h1>Create</h1>
        
    <h4>Plant Variety</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Variety.CommonNameName" class="control-label">Plant Type</label>
                <select asp-for="Variety.CommonNameName" class ="form-control" asp-items="ViewBag.CommonName" ></select>
            </div>
            <div class="form-group">
                <label asp-for="Variety.VarietyName" class="control-label">Variety Name</label>
                <input asp-for="Variety.VarietyName" class ="form-control">
            </div>
            <div class="form-group">
                <label asp-for="Variety.Depth" class="control-label">Planting Depth</label>
                <input asp-for="Variety.Depth" class ="form-control">
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
    <div>
    </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    }