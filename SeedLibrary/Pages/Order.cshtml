@page
@model SeedLibrary.Pages.Order.OrderModel

@{
    ViewData["Title"] = "Order Seeds";
}

<link rel="stylesheet" type="text/css" href="css/spotlight.css">

<div class="row mb-auto">
    <div class="row  mb-4">
        <h2>Order Seeds</h2>
    <form method="post">
        <div class="container">
            <div class="row">
                @for (int i = 0; i < Model.Seeds.Count; i++)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card bg-light border-danger p-3">
                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                    type="checkbox"
                                    name="SelectedSeeds"
                                    value="@Model.Seeds[i].ID" />
                                <label class="form-check-label"></label>
                            </div>
                            <h3>@Model.Seeds[i].Name</h3>
                            <p>
                                <b>Variety:</b> @Model.Seeds[i].Variety <br />
                                <b>Year:</b> @Model.Seeds[i].Year <br />
                                <b>Date:</b> @Model.Seeds[i].Date <br />
                                <b>Count:</b> @Model.Seeds[i].Count
                            </p>
                        </div>
                    </div>
                }
            </div>
            <a asp-page="/About" class="btn btn-primary">
                Add to Order
            </a>
        </form>
    </div>
</div>